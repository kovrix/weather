{
  "expo": {
    "name": "Weather",
    "slug": "weather-provider-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "icon": "./assets/screenshots/weather.png",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "bundleIdentifier": "com.anonymous.weather-provider-app",
      "bundleDisplayName": "Weather",
      "icon": "./assets/screenshots/weather.png",
      "supportsTabletMode": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Allow Weather to use your location to fetch local weather conditions."
      }
    },
    "android": {
      "package": "com.anonymous.weatherproviderapp"
    },
    "plugins": [
      "expo-asset",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow Weather to use your location to fetch local weather."
        }
      ]
    ],
    "web": {
      "bundler": "metro"
    }
  }
}